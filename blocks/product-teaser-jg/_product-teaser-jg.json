{
  "definitions": [
    {
      "title": "Product Teaser JG",
      "id": "product-teaser-jg",
      "model": "product-teaser-jg",
      "plugins": {
        "da": {
          "unsafeHTML": "<div class=\"product-teaser-jg\"><div><div>sku</div><div></div></div><div><div>details-button</div><div>true</div></div><div><div>cart-button</div><div>true</div></div><div><div>background-color</div><div>#003087</div></div><div><div>text-color</div><div>#ffffff</div></div><div><div>button-color</div><div>#ffffff</div></div><div><div>button-text-color</div><div>#003087</div></div></div>",
          "fields": [
            {
              "name": "sku",
              "selector": "div:nth-child(1)>div:nth-child(2)"
            },
            {
              "name": "details-button",
              "selector": "div:nth-child(2)>div:nth-child(2)"
            },
            {
              "name": "cart-button",
              "selector": "div:nth-child(3)>div:nth-child(2)"
            },
            {
              "name": "background-color",
              "selector": "div:nth-child(4)>div:nth-child(2)"
            },
            {
              "name": "text-color",
              "selector": "div:nth-child(5)>div:nth-child(2)"
            },
            {
              "name": "button-color",
              "selector": "div:nth-child(6)>div:nth-child(2)"
            },
            {
              "name": "button-text-color",
              "selector": "div:nth-child(7)>div:nth-child(2)"
            }
          ]
        }
      }
    }
  ],
  "models": [
    {
      "id": "product-teaser-jg",
      "fields": [
        {
          "component": "text",
          "valueType": "string",
          "name": "sku",
          "label": "Product SKU",
          "description": "The SKU of the product to display",
          "required": true
        },
        {
          "component": "boolean",
          "name": "details-button",
          "label": "Show Details Button",
          "valueType": "boolean",
          "value": true
        },
        {
          "component": "boolean",
          "name": "cart-button",
          "label": "Show Add to Cart Button",
          "valueType": "boolean",
          "value": true
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "background-color",
          "label": "Background Color",
          "value": "#003087",
          "description": "Card background — any valid CSS color (e.g. #003087, blue, rgb(0,48,135))"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "text-color",
          "label": "Text Color",
          "value": "#ffffff",
          "description": "Text color for product name, SKU, price, and description"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "button-color",
          "label": "Details Button Background Color",
          "value": "#ffffff",
          "description": "Background color of the Details button (default: same as text-color)"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "button-text-color",
          "label": "Details Button Text Color",
          "value": "#003087",
          "description": "Text color of the Details button (default: same as background-color)"
        }
      ]
    }
  ],
  "filters": []
}
