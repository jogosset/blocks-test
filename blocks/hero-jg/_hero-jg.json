{
  "definitions": [
    {
      "title": "Hero (JPG)",
      "id": "hero-jg",
      "model": "hero-jg",
      "plugins": {
        "da": {
          "unsafeHTML": "<div class=\"hero-jg\"><div><div><picture><source type=\"image/webp\" srcset=\"\"><source type=\"image/jpeg\" srcset=\"\"><img loading=\"lazy\" alt=\"\"></picture><h2>Hero Title</h2><h3>Hero Subtitle</h3><p>Hero description text</p><p><a href=\"\">Shop Now</a></p></div></div><div><div>text-color</div><div>#ffffff</div></div><div><div>cta-button-opacity</div><div>24</div></div></div>",
          "fields": [
            {
              "name": "image",
              "selector": "div:nth-child(1)>div:nth-child(1)>picture:nth-child(1)>img[src]"
            },
            {
              "name": "imageAlt",
              "selector": "div:nth-child(1)>div:nth-child(1)>picture:nth-child(1)>img[alt]"
            },
            {
              "name": "title",
              "selector": "div:nth-child(1)>div:nth-child(1)>h2:nth-child(2)"
            },
            {
              "name": "subtitle",
              "selector": "div:nth-child(1)>div:nth-child(1)>h3:nth-child(3)"
            },
            {
              "name": "description",
              "selector": "div:nth-child(1)>div:nth-child(1)>p:nth-child(4)"
            },
            {
              "name": "ctaLabel",
              "selector": "div:nth-child(1)>div:nth-child(1)>p:nth-child(5)>a:nth-child(1)"
            },
            {
              "name": "ctaUrl",
              "selector": "div:nth-child(1)>div:nth-child(1)>p:nth-child(5)>a:nth-child(1)[href]"
            },
            {
              "name": "text-color",
              "selector": "div:nth-child(2)>div:nth-child(2)"
            },
            {
              "name": "cta-button-opacity",
              "selector": "div:nth-child(3)>div:nth-child(2)"
            }
          ]
        }
      }
    }
  ],
